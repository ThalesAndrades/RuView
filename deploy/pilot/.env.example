# RuView pilot — sensing-server configuration. Copy to `.env` and edit.
# These map to the sensing-server's env-backed CLI flags (see `docs/integrations/home-assistant.md`).

# ── Data source ──────────────────────────────────────────────────────
# esp32      : receive real CSI frames from ESP32 nodes on UDP :5005 (pilot default)
# simulate   : synthetic data, no hardware — use this to demo the HA entities first
# auto       : probe for ESP32, fall back to simulate
CSI_SOURCE=esp32

# Log level for the server (error|warn|info|debug|trace)
RUST_LOG=info

# ── MQTT / Home Assistant (ADR-115 §3.8) ─────────────────────────────
RUVIEW_MQTT=true
RUVIEW_MQTT_HOST=mosquitto
RUVIEW_MQTT_PORT=1883
RUVIEW_MQTT_PREFIX=homeassistant

# Broker credentials. Leave blank for the anonymous pilot default; set both
# (and harden mosquitto.conf) before a real deployment. The password is read
# from the env var NAMED here (default MQTT_PASSWORD), never passed on the CLI.
RUVIEW_MQTT_USERNAME=
MQTT_PASSWORD=

# ── Privacy (ADR-115 §3.10) ──────────────────────────────────────────
# true  : strip raw heart-rate / breathing-rate / pose from MQTT; the inferred
#         semantic states (sleeping, no-movement, bed-exit, …) STILL publish.
#         Good fit for bedrooms/bathrooms where vitals values feel invasive.
# false : publish raw vitals too.
RUVIEW_PRIVACY_MODE=false

# ── Models (optional) ────────────────────────────────────────────────
# Mount a host dir of .rvf files in docker-compose.yml and point here.
# Without a model the server runs on heuristics (presence/motion still work).
MODELS_DIR=data/models
